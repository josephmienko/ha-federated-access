server {
	listen 80 default_server;
	listen [::]:80 default_server;

    root /usr/share/nginx/html;
    location = /netbird.wasm {
        root /usr/share/nginx/html;
        default_type application/wasm;
    }
    location = /ironrdp-pkg/ironrdp_web_bg.wasm {
        root /usr/share/nginx/html;
        default_type application/wasm;
    }

    location / {
      try_files $$uri $$uri.html $$uri/ =404;
      add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0";
      expires off;
   }

   error_page 404 /404.html;
   location = /404.html {
      internal;
      add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0";
      expires off;
   }
}

server {
	listen 80;
	listen [::]:80;
    server_name ${NETBIRD_DOMAIN};

    resolver 127.0.0.11 ipv6=off valid=30s;
    resolver_timeout 5s;

    root /usr/share/nginx/html;

    location = /netbird.wasm {
        root /usr/share/nginx/html;
        default_type application/wasm;
    }

    location = /ironrdp-pkg/ironrdp_web_bg.wasm {
        root /usr/share/nginx/html;
        default_type application/wasm;
    }

    location /api/ {
        set $$management_http http://management:443;
        proxy_pass $$management_http;
        proxy_http_version 1.1;
        proxy_set_header Host $$host;
        proxy_set_header X-Real-IP $$remote_addr;
        proxy_set_header X-Forwarded-For $$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $$scheme;
        proxy_read_timeout 3600s;
    }

    location /oauth2/ {
        set $$management_http http://management:443;
        proxy_pass $$management_http;
        proxy_http_version 1.1;
        proxy_set_header Host $$host;
        proxy_set_header X-Real-IP $$remote_addr;
        proxy_set_header X-Forwarded-For $$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $$scheme;
        proxy_read_timeout 3600s;
    }

    location /ws-proxy/management {
        set $$management_ws http://management:443;
        proxy_pass $$management_ws;
        proxy_http_version 1.1;
        proxy_set_header Host $$host;
        proxy_set_header X-Real-IP $$remote_addr;
        proxy_set_header X-Forwarded-For $$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $$scheme;
        proxy_set_header Upgrade $$http_upgrade;
        proxy_set_header Connection $$connection_upgrade;
        proxy_read_timeout 3600s;
    }

    location /management.ManagementService/ {
        set $$management_grpc management:443;
        grpc_pass grpc://$$management_grpc;
        grpc_set_header Host $$host;
        grpc_set_header X-Real-IP $$remote_addr;
        grpc_set_header X-Forwarded-For $$proxy_add_x_forwarded_for;
        grpc_set_header X-Forwarded-Proto $$scheme;
        grpc_read_timeout 3600s;
    }

    location / {
      try_files $$uri $$uri.html $$uri/ =404;
      add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0";
      expires off;
   }

   error_page 404 /404.html;
   location = /404.html {
      internal;
      add_header Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0";
      expires off;
   }
}
