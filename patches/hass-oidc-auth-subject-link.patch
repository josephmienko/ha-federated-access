diff -ruN -x __pycache__ -x *.pyc orig/custom_components/auth_oidc/endpoints/injected_auth_page.py mod/custom_components/auth_oidc/endpoints/injected_auth_page.py
--- orig/custom_components/auth_oidc/endpoints/injected_auth_page.py	1969-12-31 16:00:00
+++ mod/custom_components/auth_oidc/endpoints/injected_auth_page.py	2026-04-19 00:27:18
@@ -0,0 +1,211 @@
+"""Injected authorization page, replacing the original."""
+
+import base64
+import json
+import logging
+from functools import partial
+from pathlib import Path
+from urllib.parse import quote, unquote
+
+from aiofiles import open as async_open
+from aiohttp import web
+from homeassistant.components.http import HomeAssistantView, StaticPathConfig
+from homeassistant.core import HomeAssistant
+
+from .welcome import PATH as WELCOME_PATH
+from ..helpers import get_url
+
+PATH = "/auth/authorize"
+
+_LOGGER = logging.getLogger(__name__)
+
+
+async def read_file(path: str) -> str:
+    """Read a file from the static path."""
+    async with async_open(path, mode="r") as f:
+        return await f.read()
+
+
+def script_var_assignment(name: str, value) -> str:
+    """Safely serialize a window assignment into an inline script."""
+    payload = json.dumps(value, separators=(",", ":")).replace("<", "\\u003c")
+    return f"<script>window.{name} = {payload};</script>"
+
+
+def auth_branding_assignment(branding: dict | None) -> str:
+    """Serialize auth branding using the ha-branding-overrides config seam."""
+    if not isinstance(branding, dict) or not branding:
+        return ""
+
+    auth_branding = (
+        branding.get("auth") if isinstance(branding.get("auth"), dict) else branding
+    )
+    return script_var_assignment(
+        "ha_branding_overrides",
+        {"auth": {"enabled": True, **auth_branding}},
+    )
+
+
+def build_static_paths(static_root: Path) -> list[StaticPathConfig]:
+    """Build auth_oidc static routes, including optional branding assets."""
+    static_paths = [
+        StaticPathConfig(
+            "/auth/oidc/static/injection.js",
+            str(static_root / "injection.js"),
+            cache_headers=False,
+        ),
+        StaticPathConfig(
+            "/auth/oidc/static/style.css",
+            str(static_root / "style.css"),
+            cache_headers=False,
+        ),
+    ]
+
+    for route, filename in (
+        ("/auth/oidc/static/ha-branding-overrides.js", "ha-branding-overrides.js"),
+        ("/auth/oidc/static/favicon-32.png", "favicon-32.png"),
+        ("/auth/oidc/static/favicon-192.png", "favicon-192.png"),
+        ("/auth/oidc/static/auth-logo-light.svg", "auth-logo-light.svg"),
+        ("/auth/oidc/static/auth-logo-dark.svg", "auth-logo-dark.svg"),
+        ("/auth/oidc/static/logo.png", "logo.png"),
+        ("/auth/oidc/static/logo.svg", "logo.svg"),
+        ("/auth/oidc/static/logo-light.svg", "logo-light.svg"),
+        ("/auth/oidc/static/logo-dark.svg", "logo-dark.svg"),
+    ):
+        asset_path = static_root / filename
+        if asset_path.is_file():
+            static_paths.append(
+                StaticPathConfig(
+                    route,
+                    str(asset_path),
+                    cache_headers=False,
+                )
+            )
+
+    return static_paths
+
+
+async def frontend_injection(
+    hass: HomeAssistant,
+    sso_name: str,
+    force_https: bool,
+    branding: dict | None = None,
+) -> None:
+    """Inject new frontend code into /auth/authorize."""
+    router = hass.http.app.router
+    frontend_path = None
+
+    for resource in router.resources():
+        if resource.canonical != "/auth/authorize":
+            continue
+
+        # This path does not work, effectively disabling the old matcher.
+        resource.add_prefix("/auth/oidc/unused")
+
+        # Get the original frontend path from this resource to obtain the GET route.
+        routes = iter(resource)
+        route = next(
+            (r for r in routes if r.method == "GET"),
+            None,
+        )
+
+        if route is not None:
+            if not route.handler or not isinstance(route.handler, partial):
+                _LOGGER.warning(
+                    "Unexpected route handler type %s for /auth/authorize",
+                    type(route.handler),
+                )
+                continue
+
+            # The original frontend path is the first argument of the handler.
+            frontend_path = route.handler.args[0]
+            break
+
+    # Get the path to the original frontend resource.
+    if frontend_path is None:
+        _LOGGER.info(
+            "Failed to find GET route for /auth/authorize, cannot inject OIDC frontend code"
+        )
+        return
+
+    # Inject our scripts into the existing frontend code.
+    frontend_code = await read_file(frontend_path)
+    static_root = Path(hass.config.path("custom_components/auth_oidc/static"))
+    branding_js = auth_branding_assignment(branding)
+    sso_name_js = script_var_assignment("sso_name", sso_name)
+    branding_module_js = (
+        "<script src='/auth/oidc/static/ha-branding-overrides.js?v=1'></script>"
+        if (static_root / "ha-branding-overrides.js").is_file()
+        else ""
+    )
+    injection_js = "<script src='/auth/oidc/static/injection.js?v=12'></script>"
+    frontend_code = frontend_code.replace(
+        "</body>",
+        f"{branding_js}{sso_name_js}{branding_module_js}{injection_js}</body>",
+    )
+
+    await hass.http.async_register_static_paths(build_static_paths(static_root))
+
+    # If everything is successful, register a fake view that returns the modified HTML.
+    hass.http.register_view(OIDCInjectedAuthPage(frontend_code, force_https))
+    _LOGGER.info("Performed OIDC frontend injection")
+
+
+class OIDCInjectedAuthPage(HomeAssistantView):
+    """OIDC Plugin Injected Auth Page."""
+
+    requires_auth = False
+    url = PATH
+    name = "auth:oidc:authorize_page"
+
+    def __init__(self, html: str, force_https: bool) -> None:
+        """Initialize the injected auth page."""
+        self.html = html
+        self.force_https = force_https
+
+    @staticmethod
+    async def inject(
+        hass: HomeAssistant,
+        sso_name: str,
+        force_https: bool,
+        branding: dict | None = None,
+    ) -> None:
+        """Inject the OIDC auth page into the frontend."""
+        try:
+            await frontend_injection(hass, sso_name, force_https, branding)
+        except Exception as e:  # pylint: disable=broad-except
+            _LOGGER.error("Failed to inject OIDC auth page: %s", e)
+
+    @staticmethod
+    def _should_do_oidc_redirect(req: web.Request) -> bool:
+        """Check if we should redirect to the OIDC flow."""
+        # Set when we return from finish.
+        if req.query.get("skip_oidc_redirect") == "true":
+            return False
+
+        # Set whenever you directly do /?skip_oidc_redirect=true,
+        # for example when you click the "other" button on the welcome screen.
+        redirect_uri = req.query.get("redirect_uri")
+        if not redirect_uri:
+            return False
+
+        # Handle both encoded and plain redirect_uri values.
+        decoded_redirect_uri = unquote(redirect_uri)
+        return "skip_oidc_redirect=true" not in decoded_redirect_uri
+
+    def _get_welcome_redirect_location(self, req: web.Request) -> str:
+        """Build the welcome URL for the injected auth page redirect."""
+        encoded_current_url = quote(
+            base64.b64encode(str(req.url).encode("utf-8")).decode("ascii")
+        )
+        return get_url(
+            f"{WELCOME_PATH}?redirect_uri={encoded_current_url}",
+            self.force_https,
+        )
+
+    async def get(self, req: web.Request) -> web.Response:
+        """Return the original page or redirect into the OIDC flow."""
+        if self._should_do_oidc_redirect(req):
+            raise web.HTTPFound(location=self._get_welcome_redirect_location(req))
+
+        return web.Response(text=self.html, content_type="text/html")
