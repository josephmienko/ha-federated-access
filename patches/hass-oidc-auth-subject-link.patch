diff -ruN -x __pycache__ -x *.pyc orig/custom_components/auth_oidc/stores/subject_link_store.py mod/custom_components/auth_oidc/stores/subject_link_store.py
--- orig/custom_components/auth_oidc/stores/subject_link_store.py	1969-12-31 16:00:00
+++ mod/custom_components/auth_oidc/stores/subject_link_store.py	2026-04-19 00:25:04
@@ -0,0 +1,113 @@
+"""Durable subject-link storage for OIDC credentials."""
+
+from datetime import datetime, timezone
+from typing import Optional, cast
+
+from homeassistant.core import HomeAssistant
+from homeassistant.helpers.storage import Store
+
+from ..types import SubjectLinkRecord
+
+STORAGE_VERSION = 1
+STORAGE_KEY = "auth_provider.auth_oidc.subject_links"
+
+
+class SubjectLinkStore:
+    """Persist issuer+subject to credential links."""
+
+    def __init__(self, hass: HomeAssistant) -> None:
+        self.hass = hass
+        self._store = Store[dict](
+            hass, STORAGE_VERSION, STORAGE_KEY, private=True, atomic_writes=True
+        )
+        self._data: dict | None = None
+
+    async def async_load(self) -> None:
+        """Load stored data."""
+        if (data := await self._store.async_load()) is None:
+            data = {"subjects": {}}
+
+        if not isinstance(data, dict):
+            data = {"subjects": {}}
+
+        subjects = data.get("subjects")
+        if not isinstance(subjects, dict):
+            subjects = {}
+
+        self._data = {"subjects": subjects}
+
+    async def _async_save(self) -> None:
+        """Save data."""
+        if self._data is not None:
+            await self._store.async_save(self._data)
+
+    def _subjects(self) -> dict[str, dict[str, SubjectLinkRecord]]:
+        if self._data is None:
+            raise RuntimeError("Data not loaded")
+        subjects = self._data.setdefault("subjects", {})
+        return cast(dict[str, dict[str, SubjectLinkRecord]], subjects)
+
+    async def async_get_link(
+        self, issuer: str, sub: str
+    ) -> Optional[SubjectLinkRecord]:
+        """Get a stored subject link."""
+        return self._subjects().get(issuer, {}).get(sub)
+
+    async def async_set_link(
+        self,
+        issuer: str,
+        sub: str,
+        credential_id: str,
+        user_id: Optional[str],
+        email_at_link: Optional[str],
+        bootstrap_method: str,
+    ) -> None:
+        """Set or update a stored subject link."""
+        now = datetime.now(timezone.utc).isoformat()
+        issuer_links = self._subjects().setdefault(issuer, {})
+        record = dict(issuer_links.get(sub, {}))
+        record["credential_id"] = credential_id
+        record["bootstrap_method"] = bootstrap_method
+        record["last_seen_at"] = now
+        record["linked_at"] = record.get("linked_at", now)
+        record["user_id"] = user_id
+        record["email_at_link"] = email_at_link
+        issuer_links[sub] = cast(SubjectLinkRecord, record)
+        await self._async_save()
+
+    async def async_set_user_id(self, issuer: str, sub: str, user_id: str) -> None:
+        """Backfill the user ID once HA creates or links the user."""
+        record = await self.async_get_link(issuer, sub)
+        if record is None:
+            return
+
+        record["user_id"] = user_id
+        record["last_seen_at"] = datetime.now(timezone.utc).isoformat()
+        await self._async_save()
+
+    async def async_touch(self, issuer: str, sub: str) -> None:
+        """Update the last-seen timestamp for a subject link."""
+        record = await self.async_get_link(issuer, sub)
+        if record is None:
+            return
+
+        record["last_seen_at"] = datetime.now(timezone.utc).isoformat()
+        await self._async_save()
+
+    async def async_remove_by_credential_id(self, credential_id: str) -> None:
+        """Remove a stored link by credential ID."""
+        subjects = self._subjects()
+        removed = False
+
+        for issuer in list(subjects):
+            issuer_links = subjects[issuer]
+            for sub in list(issuer_links):
+                if issuer_links[sub].get("credential_id") == credential_id:
+                    del issuer_links[sub]
+                    removed = True
+
+            if not issuer_links:
+                del subjects[issuer]
+
+        if removed:
+            await self._async_save()
